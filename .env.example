# Environment variables — copy to .env.local and fill in your values

# Supabase
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Required for seed script (server-side admin only — never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: for password-reset redirect URL (defaults to localhost:3000)
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Optional: email notifications via Resend (https://resend.com)
# If not set, emails are silently skipped (inquiry confirmations, reply notifications)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Vistera <noreply@yourdomain.com>
